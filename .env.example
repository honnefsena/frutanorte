# SendGrid — crie em https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# Remetente verificado no SendGrid (single sender ou domínio autenticado)
FROM_EMAIL=noreply@seudominio.com.br

# Caixa que recebe os formulários do site
TO_EMAIL=contato@seudominio.com.br

# Porta local da API Node (opcional; padrão 3000)
PORT=3000

# Origens permitidas no CORS, separadas por vírgula (dev + produção)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost,http://127.0.0.1:5500,http://localhost:8080,https://www.frutanorte.com.br
